{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask dev server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["app.py"],
      "port": 5000,
      "autoPort": true
    },
    {
      "name": "Gunicorn (prod-like)",
      "runtimeExecutable": "gunicorn",
      "runtimeArgs": ["app:app", "--bind", "0.0.0.0:5000"],
      "port": 5000
    }
  ]
}
